@PACKAGE_INIT@
#
# VxlStudioConfig.cmake  --  find_package(VxlStudio) support
#
# Provides:
#   VxlStudio_FOUND       - TRUE if found
#   VxlStudio_INCLUDE_DIR - path to vxl/ headers
#   VxlStudio_LIBRARY_DIR - path to libvxl_core
#   VxlStudio_PYTHON_DIR  - path to Python vxl package
#   VxlStudio_VERSION     - version string
#

set(VxlStudio_VERSION "@PROJECT_VERSION@")

# Compute install prefix relative to this file's location
get_filename_component(_install_prefix "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)

set(VxlStudio_INCLUDE_DIR "${_install_prefix}/include")
set(VxlStudio_LIBRARY_DIR "${_install_prefix}/lib")
set(VxlStudio_PYTHON_DIR  "${_install_prefix}/lib/python")

# Verify the header directory exists
if(NOT EXISTS "${VxlStudio_INCLUDE_DIR}/vxl")
    set(VxlStudio_FOUND FALSE)
    if(VxlStudio_FIND_REQUIRED)
        message(FATAL_ERROR "VxlStudio headers not found at ${VxlStudio_INCLUDE_DIR}/vxl")
    endif()
    return()
endif()

set(VxlStudio_FOUND TRUE)

# Create imported target if the library exists
find_library(VxlStudio_CORE_LIBRARY
    NAMES vxl_core
    PATHS "${VxlStudio_LIBRARY_DIR}"
    NO_DEFAULT_PATH
)

if(VxlStudio_CORE_LIBRARY AND NOT TARGET VxlStudio::vxl_core)
    add_library(VxlStudio::vxl_core SHARED IMPORTED)
    set_target_properties(VxlStudio::vxl_core PROPERTIES
        IMPORTED_LOCATION "${VxlStudio_CORE_LIBRARY}"
        INTERFACE_INCLUDE_DIRECTORIES "${VxlStudio_INCLUDE_DIR}"
    )
endif()

unset(_install_prefix)
